
{
  "manifest_version": 3,
  "name": "Instagram Scraper",
  "version": "1.0",
  "description": "Scrape Instagram Contents",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "icons":{
    "128":"logo.png"
  },
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "start-scraping": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y",
        "linux": "Ctrl+Shift+Y"
      },
      "description": "Start scraping Instagram posts"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Scraper"
  }
}
